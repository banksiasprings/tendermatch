rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Tenders: anyone can read, authenticated users can create
    match /tenders/{tenderId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.postedBy;
    }
    // Bids: authenticated users only, owner can read their own
    match /bids/{bidId} {
      allow read: if request.auth != null &&
        (request.auth.uid == resource.data.userId ||
         request.auth.uid == get(/databases/$(database)/documents/tenders/$(resource.data.tenderId)).data.postedBy);
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    // Suppliers: anyone can read, authenticated users manage their own
    match /suppliers/{supplierId} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == supplierId;
    }
    // Q&A threads: anyone can read, auth users can post
    match /questions/{questionId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    // User profiles
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    // Seed/meta
    match /_meta/{doc} {
      allow read, write: if true;
    }
  }
}
